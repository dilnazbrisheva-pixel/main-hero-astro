---
import './terms.scss';

type SectionItem = {
  content?: string[];
  list?: string[];
};

type DocumentSection = {
  number: string;
  title: string;
  items: SectionItem[];
};

const slabSections: DocumentSection[] = [
  {
    number: '1',
    title: 'Назначение Сервиса',
    items: [
      {
        content: [
          '1.1. DOIT — модуль автоматизации телефонных разговоров через Битрикс24.',
          '1.2. Основные функции модуля:',
        ],
        list: [
          'Загрузка в модальное окно звонка системы Битрикс24',
          'Редактирование полей в карточке сделки',
          'Редактирование этапов карточки сделки',
          'Отображение интерактивного скрипта в зависимости от выбранного поля',
          'Запись данных в карточку CRM',
          'Редактирование товаров в карточке CRM',
        ],
      },
    ],
  },
  {
    number: '2',
    title: 'Интеграции',
    items: [
      {
        content: ['2.1. DOIT интегрируется со следующими системами и каналами:'],
        list: ['CRM-системы (Bitrix24)'],
      },
      {
        content: [
          '2.2. Администратор оставляет за собой право расширять список интеграций и добавлять новые каналы связи.',
        ],
      },
    ],
  },
  {
    number: '3',
    title: 'Тарифные планы',
    items: [
      {
        content: ['3.1. DOIT предоставляется на условиях подписки. Доступные тарифы:'],
        list: [
          '1 месяц — 27 600 тенге',
          '12 месяцев — 264 960 тенге (экономия 20 процентов)',
        ],
      },
      {
        content: [
          '3.2. Пробный период: 14 дней бесплатно с доступом ко всем функциям тарифа.',
          '3.3. Актуальные цены и условия тарифов публикуются на сайте Правообладателя.',
        ],
      },
    ],
  },
  {
    number: '4',
    title: 'Уровень обслуживания (SLA)',
    items: [
      {
        content: [
          '4.1. Плановые работы проводятся в ночное время (с 02:00 до 05:00 по времени Алматы) с предварительным уведомлением не менее чем за 24 часа.',
          '4.2. Техническая поддержка:',
        ],
        list: [
          'Базовый и Стандартный тарифы: email-поддержка, ответ в течение 24 часов',
          'Партнёрский: приоритетная поддержка, ответ в течение 4 часов.',
        ],
      },
    ],
  },
  {
    number: '5',
    title: 'Ограничения и требования',
    items: [
      {
        content: ['5.1. Для корректной работы Сервиса требуется:'],
        list: [
          'стабильное интернет-соединение',
          'современный веб-браузер (Chrome, Firefox, Safari последних версий)',
          'активные учётные записи в интегрируемых системах.',
        ],
      },
      {
        content: [
          '5.2. Администратор не несёт ответственности за сбои, вызванные некорректными настройками интеграций или действиями третьих сторон.',
        ],
      },
    ],
  },
  {
    number: '6',
    title: 'Хранение и обработка данных',
    items: [
      {
        content: ['6.1. Сервис обрабатывает и хранит следующие данные:'],
        list: [
          'информация о задачах (описание, статусы, сроки, ответственные)',
          'данные пользователей (имя, email, телефон, должность)',
          'записи коммуникаций с клиентами (при использовании функции анализа эмоций)',
          'технические данные (логи, метрики использования).',
        ],
      },
      {
        content: [
          '6.2. Все данные хранятся на серверах Заказчика.',
          '6.3. Подробная информация о защите данных приведена в Политике конфиденциальности Gamechanger.',
        ],
      },
    ],
  },
  {
    number: '7',
    title: 'Особые условия',
    items: [
      {
        content: [
          '7.1. Администратор не несёт ответственности за интерпретацию результатов модуля и решения, принятые на их основе.',
        ],
      },
    ],
  },
  {
    number: '8',
    title: 'Прекращение использования',
    items: [
      {
        content: [
          '8.1. При расторжении подписки или удалении учётной записи данные задач и пользователей хранятся в течение 30 дней для возможности восстановления доступа.',
          '8.2. По истечении 30 дней данные удаляются безвозвратно, если Пользователь не запросил их экспорт.',
        ],
      },
    ],
  },
  {
    number: '9',
    title: 'Заключительные положения',
    items: [
      {
        content: [
          '9.1. Настоящее Приложение является неотъемлемой частью Пользовательского соглашения об использовании сервисов Gamechanger.',
          '9.2. В случае противоречия между условиями Приложения и основного Соглашения, приоритет имеют условия Приложения в части, касающейся использования Сервиса DOIT.',
          '9.3. Администратор оставляет за собой право вносить изменения в настоящее Приложение с уведомлением Пользователей не менее чем за 7 дней.',
        ],
      },
    ],
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Условия работы</title>
  </head>
  <body>
    <main class="terms-page">
      <div class="terms-page__container">
        <a href="/" class="terms-page__back">← Вернуться назад</a>

        <section class="document-card">
          <div class="document-card__header">
            <h1 class="document-card__title">Условия использования Сервиса DOIT</h1>
            <p class="document-card__intro">
              Правообладатель — ТОО "Gamechanger", БИН 230940024402, Республика Казахстан,
              г. Алматы, предоставляющее доступ к Сервисам.
            </p>
          </div>

          <div class="document-card__content">
            {slabSections.map((section) => (
              <section class="document-section">
                <h2 class="document-section__title">
                  {section.number}. {section.title}
                </h2>

                <div class="document-section__items">
                  {section.items.map((item) => (
                    <div class="document-section__item">
                      {item.content?.map((paragraph) => (
                        <p class="document-section__text">{paragraph}</p>
                      ))}

                      {item.list && (
                        <ul class="document-section__list">
                          {item.list.map((point) => (
                            <li>{point}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            ))}

            <article class="document-card__company">
              <div class="document-card__company-item">ТОО "Gamechanger"</div>
              <div class="document-card__company-item">БИН: 230940024402</div>
              <div class="document-card__company-item document-card__company-item--address">
                Адрес: Республика Казахстан,<br />
                г. Караганда, ул. Заводская 17/1, офис 7
              </div>
            </article>
          </div>
        </section>
      </div>
    </main>
  </body>
</html>
